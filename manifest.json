{
  "manifest_version": 3,
  "name": "Codeforces to Baekjoon",
  "version": "3.3",
  "description": "Codeforces 백준 스타일 통합 렌더링 및 검색 엔진 (v3.3)",
  "permissions": ["storage"],
  "host_permissions": ["https://codeforces.com/api/*"],
  "content_scripts": [
    {
      "matches": ["*://codeforces.com/*"],
      "css": [
        "styles/variables.css",
        "styles/components.css",
        "styles/overrides.css"
      ],
      "js": [
        "theme-init.js",
        "src/utils/domObserver.js",
        "src/utils/debounce.js",
        "src/utils/sanitizer.js",
        "src/core/tierCalculator.js",
        "src/core/stateManager.js",
        "src/core/queryParser.js",
        "src/api/fetcher.js",
        "src/components/themeToggle.js",
        "src/components/pillContainer.js",
        "src/components/searchBar.js",
        "src/components/spoilerToggle.js",
        "src/pages/problem.js",
        "src/pages/problemset.js",
        "src/pages/profile.js",
        "src/pages/status.js",
        "main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg", "icons/*.png"],
      "matches": ["*://codeforces.com/*"]
    }
  ]
}